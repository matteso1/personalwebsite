# Copy to .env.local and fill in. Both values are safe to expose in the browser:
# the anon key is designed to be public; row-level security on the `posts`
# table enforces who can read drafts and who can write.
#
# Find both at: Supabase dashboard → Project → Settings → API.
# DO NOT put the personal access token (sbp_…), service role key, or DB
# password here — none of them belong in a frontend bundle.

VITE_SUPABASE_URL=https://nwbgxhjnxwyrolidmwqh.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
