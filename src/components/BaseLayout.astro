---
import '../styles/global.css';
import BaseHead from './BaseHead.astro';
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  mdPath?: string;
  ogType?: 'website' | 'article' | 'profile';
  isHome?: boolean;
  showHeader?: boolean;
  article?: { date?: string; modified?: string; tags?: string[] };
}

const { showHeader = true, isHome = false, ...rest } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead isHome={isHome} {...rest} />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <SiteHeader />
    <main id="main">
      <div class="column">
        <slot />
      </div>
    </main>
    <SiteFooter />
  </body>
</html>
