---
import '@fontsource-variable/source-serif-4';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import BaseHead from './BaseHead.astro';
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  mdPath?: string;
  ogType?: 'website' | 'article' | 'profile';
  isHome?: boolean;
  showHeader?: boolean;
  article?: { date?: string; modified?: string; tags?: string[] };
}

const { showHeader = true, isHome = false, ...rest } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Set the theme before first paint so there is no flash.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <BaseHead isHome={isHome} {...rest} />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    {showHeader && <SiteHeader minimal={isHome} />}
    <main id="main">
      <div class="column">
        <slot />
      </div>
    </main>
    <SiteFooter />
  </body>
</html>
