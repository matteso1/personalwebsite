---
const path = Astro.url.pathname;
const is = (p: string) => {
  if (p === '/') return path === '/';
  return path === p || path.startsWith(p + '/') || path.startsWith(p + '.');
};

// Stamped at build time (Pacific), so it tracks the last deploy instead of
// going stale — and stays correct regardless of the build server's timezone.
const buildDate = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'America/Los_Angeles',
}).format(new Date());
---

<nav class="taskbar" aria-label="Site navigation">
  <a href="/" class="taskbar-start" aria-label="Home">
    <span class="win-flag" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </span>
    Start
  </a>
  <div class="taskbar-divider" aria-hidden="true"></div>
  <div class="taskbar-tasks">
    <a href="/" class:list={['task-btn', is('/') ? 'active' : '']}>README.txt</a>
    <a href="/work" class:list={['task-btn', is('/work') ? 'active' : '']}>work</a>
    <a href="/writing" class:list={['task-btn', is('/writing') ? 'active' : '']}>writing</a>
    <a href="/about" class:list={['task-btn', is('/about') ? 'active' : '']}>about</a>
    <a href="/agents" class:list={['task-btn', is('/agents') ? 'active' : '']}>agents</a>
    <a href="/resume.pdf" class:list={['task-btn', path === '/resume.pdf' ? 'active' : '']}>resume.pdf</a>
  </div>
  <div class="taskbar-divider" aria-hidden="true"></div>
  <div class="tray" aria-label="System tray">
    <span>no JS</span>
    <span aria-hidden="true">&#8201;</span>
    <time datetime={buildDate}>{buildDate}</time>
  </div>
</nav>
