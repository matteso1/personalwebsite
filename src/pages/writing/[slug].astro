---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const iso = d.date.toISOString().slice(0, 10);
const human = d.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout
  title={d.title}
  description={d.description}
  mdPath={`/writing/${entry.id}.md`}
  ogType="article"
  article={{ date: iso, tags: d.tags }}
  winTitle={`${entry.id}.md - Notepad`}
  winDoc={true}
>
  <article class="prose">
    <h1>{d.title}</h1>
    <p class="post-meta">
      <time datetime={iso}>{human}</time>
      {d.tags?.length ? <span style="margin-left:8px;">{d.tags.join('   ')}</span> : null}
    </p>
    <Content />
    <p style="margin-top:12px;"><a href="/writing">&larr; Back to writing</a></p>
  </article>
</BaseLayout>
