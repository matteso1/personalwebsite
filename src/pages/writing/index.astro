---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<BaseLayout
  title="Writing"
  description="Engineering notes: a speculative-decoding engine from scratch, conformal prediction for transit ETAs, and benchmarking 9 LLMs on AWS Bedrock."
  winTitle="writing - Notepad"
  winDoc={true}
>
  <article>
    <h1>Writing</h1>
    <p>
      Engineering notes, mostly about systems and applied ML. I try to name what broke,
      not only what worked.
    </p>
    <table style="width:100%;border-collapse:collapse;">
      <thead>
        <tr>
          <th style="text-align:left;padding:3px 8px;border:1px solid #808080;background:#c0c0c0;">Title</th>
          <th style="text-align:left;padding:3px 8px;border:1px solid #808080;background:#c0c0c0;white-space:nowrap;">Date</th>
        </tr>
      </thead>
      <tbody>
        {posts.map((p) => (
          <tr>
            <td style="padding:3px 8px;border:1px solid #808080;vertical-align:top;">
              <a href={`/writing/${p.id}`}>{p.data.title}</a>
              {p.data.description && <span style="display:block;font-size:12px;color:#808080;margin-top:2px;">{p.data.description}</span>}
            </td>
            <td style="padding:3px 8px;border:1px solid #808080;white-space:nowrap;font-size:12px;color:#808080;">
              <time datetime={fmt(p.data.date)}>{fmt(p.data.date)}</time>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </article>
</BaseLayout>
