---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';

const entry = await getEntry('pages', 'agents');
const { Content } = await render(entry!);
---

<BaseLayout title={entry!.data.title} description={entry!.data.description} mdPath="/agents.md">
  <article class="prose">
    <h1>{entry!.data.title}</h1>
    <Content />
  </article>
</BaseLayout>
